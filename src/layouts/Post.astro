---
import Base from './Base.astro';
import type { CollectionEntry } from 'astro:content';
import { formatDate, getSlug } from '../utils';

interface Props {
  post: CollectionEntry<'posts'>;
  category: string;
  readingTime?: string;
  description?: string;
  prevPost?: CollectionEntry<'posts'> | null;
  nextPost?: CollectionEntry<'posts'> | null;
}

const { post, category, readingTime, description, prevPost, nextPost } = Astro.props;
const { title, date, updated } = post.data;
---

<Base title={title} description={description}>
  <article>
    <header class="post-header">
      <h1>{title}</h1>
      <div class="meta">
        <span class="category">{category}</span>
        <span class="sep">·</span>
        <time datetime={date.toISOString()}>{formatDate(date)}</time>
        {readingTime && (
          <>
            <span class="sep">·</span>
            <span>{readingTime}</span>
          </>
        )}
        {updated && (
          <span class="updated">Updated {formatDate(updated)}</span>
        )}
      </div>
    </header>

    <div class="post-content">
      <slot />
    </div>

    <button class="save-image-btn" id="save-image-btn">Save as image</button>
  </article>

  <div id="image-render" style="position:absolute;left:-9999px;top:0;"></div>

  {(prevPost || nextPost) && (
    <nav class="post-nav">
      {prevPost ? (
        <a href={`/${getSlug(prevPost.slug)}`} class="post-nav-link prev">
          <span class="post-nav-label">&larr; Previous</span>
          <span class="post-nav-title">{prevPost.data.title}</span>
        </a>
      ) : <span />}
      {nextPost ? (
        <a href={`/${getSlug(nextPost.slug)}`} class="post-nav-link next">
          <span class="post-nav-label">Next &rarr;</span>
          <span class="post-nav-title">{nextPost.data.title}</span>
        </a>
      ) : <span />}
    </nav>
  )}
</Base>

<style>
  .post-header {
    margin-bottom: 2.5rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--border);
  }

  .post-header h1 {
    margin: 0 0 0.75rem 0;
  }

  .meta {
    font-size: 0.875rem;
    color: var(--muted);
  }

  .category {
    font-family: 'Libre Franklin', sans-serif;
    text-transform: uppercase;
    font-size: 0.75rem;
    letter-spacing: 0.06em;
    color: var(--accent);
  }

  .sep {
    margin: 0 0.4rem;
  }

  .updated {
    font-family: 'Libre Franklin', sans-serif;
    font-size: 0.7rem;
    font-weight: 500;
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin-left: 0.4rem;
  }

  .post-content {
    line-height: 1.7;
  }


  .post-nav {
    display: flex;
    justify-content: space-between;
    gap: 2rem;
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--border);
    font-family: 'Libre Franklin', sans-serif;
  }

  .post-nav-link {
    text-decoration: none;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    max-width: 45%;
  }

  .post-nav-link.next {
    margin-left: auto;
    text-align: right;
  }

  .post-nav-label {
    font-size: 0.75rem;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .post-nav-title {
    font-size: 0.9rem;
    color: var(--accent);
  }

  .post-nav-link:hover .post-nav-title {
    color: var(--accent-hover);
  }

  .save-image-btn {
    display: inline-block;
    margin-top: 2rem;
    font-family: 'Libre Franklin', sans-serif;
    font-size: var(--text-xs);
    font-weight: 500;
    padding: 0.7rem 1rem;
    min-height: 40px;
    border: 1px solid var(--border);
    background: transparent;
    border-radius: 4px;
    cursor: pointer;
    color: var(--muted);
    transition-property: color, border-color, opacity, scale;
    transition-duration: 0.15s;
    transition-timing-function: ease;
  }

  .save-image-btn:hover {
    border-color: var(--accent);
    color: var(--accent);
  }

  .save-image-btn:active {
    scale: 0.96;
  }

  .save-image-btn.saving {
    opacity: 0.5;
    pointer-events: none;
  }
</style>

<script is:inline>
document.getElementById('save-image-btn').addEventListener('click', async function() {
  const btn = this;
  btn.textContent = 'Generating...';
  btn.classList.add('saving');
  const { toPng } = await import('https://esm.sh/html-to-image@1.11.11');

  const isDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
  const bg = isDark ? '#1a1a1a' : '#fefefe';
  const text = isDark ? '#d4d0cb' : '#2c2c2c';
  const accent = isDark ? '#c9956b' : '#6b4423';
  const muted = isDark ? '#918b84' : '#7a756f';
  const border = isDark ? '#333130' : '#e8e6e3';

  const title = document.querySelector('.post-header h1').textContent;
  const date = document.querySelector('.post-header time').textContent;
  const content = document.querySelector('.post-content').innerHTML;
  const siteTitle = document.querySelector('.site-title')?.textContent || '';

  const container = document.getElementById('image-render');
  container.innerHTML = `
    <div id="image-target" style="
      width: 1080px;
      padding: 100px 80px;
      background: ${bg};
      color: ${text};
      font-family: 'Libre Baskerville', Georgia, serif;
    ">
      <div style="
        font-size: 48px;
        font-weight: 700;
        line-height: 1.3;
        margin-bottom: 16px;
      ">${title}</div>
      <div style="
        font-family: 'Libre Franklin', sans-serif;
        font-size: 16px;
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: 0.15em;
        color: ${muted};
        margin-bottom: 48px;
      ">${date}</div>
      <div style="
        width: 60px;
        height: 3px;
        background: ${accent};
        margin-bottom: 48px;
      "></div>
      <div style="
        font-size: 26px;
        line-height: 1.8;
      ">${content}</div>
      <div style="
        margin-top: 64px;
        padding-top: 32px;
        border-top: 1px solid ${border};
        font-family: 'Libre Baskerville', Georgia, serif;
        font-size: 18px;
        font-weight: 400;
        color: ${text};
      ">${siteTitle}</div>
    </div>
  `;

  const target = document.getElementById('image-target');
  target.querySelectorAll('p').forEach(p => {
    p.style.marginBottom = '28px';
    p.style.marginTop = '0';
  });
  target.querySelectorAll('h2, h3').forEach(h => {
    h.style.color = accent;
    h.style.fontSize = '32px';
    h.style.fontWeight = '700';
    h.style.marginTop = '32px';
    h.style.marginBottom = '20px';
  });
  target.querySelectorAll('hr').forEach(hr => {
    hr.style.border = 'none';
    hr.style.height = '1px';
    hr.style.background = border;
    hr.style.margin = '40px 0';
  });
  target.querySelectorAll('a').forEach(a => {
    a.style.color = 'inherit';
    a.style.textDecoration = 'none';
  });
  target.querySelectorAll('blockquote').forEach(bq => {
    bq.style.borderLeftColor = accent;
    bq.style.opacity = '0.85';
    bq.style.fontStyle = 'italic';
  });

  await document.fonts.ready;

  try {
    const dataUrl = await toPng(target, { width: 1080, pixelRatio: 1 });
    const link = document.createElement('a');
    const slug = window.location.pathname.split('/').filter(Boolean).pop() || 'post';
    link.download = slug + '.png';
    link.href = dataUrl;
    document.body.appendChild(link);
    link.click();
    document.body.removeChild(link);
  } catch(e) {
    console.error('Image generation failed:', e);
  }

  container.innerHTML = '';
  btn.textContent = 'Save as image';
  btn.classList.remove('saving');
});
</script>
